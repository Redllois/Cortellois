# ==========================================
# CONFIGURAÇÃO DOS SEUS DADOS
# ==========================================
API_KEY = "SUA_API_KEY_AQUI"
URL_YOUTUBE = "https://www.youtube.com/watch?v=LINK_DO_YOUTUBE_AQUI"
# ==========================================

import os
import json
import yt_dlp
from google import genai
from moviepy.editor import VideoFileClip, TextClip, CompositeVideoClip
import moviepy.video.fx.all as vfx

# Inicializa a IA
client = genai.Client(api_key=API_KEY)

def limpar_json(texto):
    texto = texto.strip()
    if texto.startswith("```"):
        texto = texto.replace("```json", "").replace("```", "").strip()
    return texto

# 1. Download
print("📥 1. Baixando vídeo do YouTube...")
ydl_opts = {
    'format': 'bestvideo[height<=720]+bestaudio/best', # Resolução menor para testar mais rápido
    'merge_output_format': 'mp4',
    'outtmpl': 'video_original.mp4',
    'overwrites': True
}
with yt_dlp.YoutubeDL(ydl_opts) as ydl:
    ydl.download([URL_YOUTUBE])

# 2. Extração de Áudio
print("🎵 2. Extraindo áudio...")
video = VideoFileClip("video_original.mp4")
video.audio.write_audiofile("audio_completo.mp3", logger=None)
video.close()

# 3. IA escolhe o corte
print("🧠 3. IA analisando e escolhendo o momento mais viral...")
arquivo_subido = client.files.upload(file="audio_completo.mp3")
prompt = (
    "Analise este áudio e encontre o trecho mais impactante ou viral. "
    "O corte deve durar entre 15 e 30 segundos no máximo. "
    "Você DEVE me responder ESTREITAMENTE no formato JSON abaixo, sem textos adicionais:\n"
    "{\n"
    '  "inicio_segundos": 10.0,\n'
    '  "fim_segundos": 30.0,\n'
    '  "titulo": "Corte de teste"\n'
    "}"
)
resposta = client.models.generate_content(model="gemini-2.5-flash", contents=[arquivo_subido, prompt])
client.files.delete(name=arquivo_subido.name)
dados_corte = json.loads(limpar_json(resposta.text))
print(f"[✓] Trecho escolhido: {dados_corte['inicio_segundos']}s até {dados_corte['fim_segundos']}s")

# 4. Cortar e Enquadrar
print("✂️ 4. Cortando e transformando em vertical (9:16)...")
clip = VideoFileClip("video_original.mp4")
clip_cortado = clip.subclip(dados_corte["inicio_segundos"], dados_corte["fim_segundos"])
largura, altura = clip_cortado.size
nova_largura = int(altura * (9 / 16))
clip_vertical = vfx.crop(clip_cortado, x_center=largura/2, y_center=altura/2, width=nova_largura, height=altura)
clip_vertical.write_videofile("corte_vertical_puro.mp4", codec="libx264", audio_codec="aac", logger=None)
clip.close()
clip_cortado.close()
clip_vertical.close()

# 5. Transcrever falas
print("✍️ 5. Transcrevendo falas para a legenda...")
video_corte = VideoFileClip("corte_vertical_puro.mp4")
video_corte.audio.write_audiofile("audio_corte.mp3", logger=None)
video_corte.close()

arquivo_corte_subido = client.files.upload(file="audio_corte.mp3")
prompt_legenda = (
    "Transcreva este áudio em português. Divida a fala em pequenos blocos de no máximo "
    "2 a 3 palavras para que a legenda mude rapidamente na tela. "
    "Você DEVE me responder ESTREITAMENTE no formato JSON abaixo, sem textos adicionais:\n"
    "{\n"
    '  "segments": [\n'
    '    {"text": "TEXTO EXEMPLO", "start": 0.5, "end": 1.5}\n'
    '  ]\n'
    "}"
)
resposta_legenda = client.models.generate_content(model="gemini-2.5-flash", contents=[arquivo_corte_subido, prompt_legenda])
client.files.delete(name=arquivo_corte_subido.name)
dados_legendas = json.loads(limpar_json(resposta_legenda.text))["segments"]

# 6. Legendar
print("🎨 6. Aplicando legendas amarelas estilo TikTok...")
video_puro = VideoFileClip("corte_vertical_puro.mp4")
largura_p, altura_p = video_puro.size
clipes_de_texto = []
for item in dados_legendas:
    txt_clip = (TextClip(item["text"].upper(), font="Liberation-Sans-Bold", fontsize=40, color="yellow", stroke_color="black", stroke_width=2, method="label")
                .set_start(item["start"])
                .set_end(item["end"])
                .set_position(('center', altura_p * 0.70)))
    clipes_de_texto.append(txt_clip)

video_final = CompositeVideoClip([video_puro] + clipes_de_texto)
video_final.write_videofile("resultado_tiktok_colab.mp4", codec="libx264", audio_codec="aac", logger=None)
video_puro.close()
video_final.close()

print("\n🎉 VÍDEO FINALIZADO COM SUCESSO!")
